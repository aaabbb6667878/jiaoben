-- ==================== 透视（Highlight） ====================
local FillColor = Color3.fromRGB(175, 25, 255)
local DepthMode = "AlwaysOnTop"
local FillTransparency = 0.5
local OutlineColor = Color3.fromRGB(255, 255, 255)
local OutlineTransparency = 0

local CoreGui = game:FindService("CoreGui")
local connections = {}

local Storage = Instance.new("Folder")
Storage.Parent = CoreGui
Storage.Name = "Highlight_Storage"

local masterEnabled = true

function Highlight(Player)
    if not masterEnabled then return end
    local old = Storage:FindFirstChild(Player.Name)
    if old then old:Destroy() end
    if connections[Player] then connections[Player]:Disconnect() end

    local hl = Instance.new("Highlight")
    hl.Name = Player.Name
    hl.FillColor = FillColor
    hl.DepthMode = DepthMode
    hl.FillTransparency = FillTransparency
    hl.OutlineColor = OutlineColor
    hl.OutlineTransparency = 0
    hl.Parent = Storage

    local char = Player.Character
    if char then hl.Adornee = char end

    connections[Player] = Player.CharacterAdded:Connect(function(c)
        if masterEnabled and hl.Parent then hl.Adornee = c end
    end)
end

function clearAllHighlights()
    for _, child in pairs(Storage:GetChildren()) do
        child:Destroy()
    end
end

function restoreAllHighlights()
    for _, p in pairs(Players:GetPlayers()) do
        Highlight(p)
    end
end

Players.PlayerAdded:Connect(function(p)
    if masterEnabled then Highlight(p) end
end)
for _, p in pairs(Players:GetPlayers()) do Highlight(p) end

Players.PlayerRemoving:Connect(function(Player)
    local name = Player.Name
    if Storage:FindFirstChild(name) then Storage[name]:Destroy() end
    if connections[Player] then connections[Player]:Disconnect() connections[Player] = nil end
end)

-- ==================== 绿色自瞄（FOV=150） ====================
local RunService = game:GetService("RunService")
local Cam = workspace.CurrentCamera
local aimbotEnabled = true
local fov = 150

local FOVring = Drawing.new("Circle")
FOVring.Visible = true
FOVring.Thickness = 2
FOVring.Color = Color3.fromRGB(0, 255, 0)
FOVring.Filled = false
FOVring.Radius = fov
FOVring.Position = Cam.ViewportSize / 2

local function lookAt(target)
    local lookVector = (target - Cam.CFrame.Position).unit
    local newCFrame = CFrame.new(Cam.CFrame.Position, Cam.CFrame.Position + lookVector)
    Cam.CFrame = newCFrame
end

local function getClosestPlayerInFOV(trg_part)
    local nearest = nil
    local last = math.huge
    local center = Cam.ViewportSize / 2
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local part = Player.Character and Player.Character:FindFirstChild(trg_part)
            if part then
                local ePos, onScreen = Cam:WorldToViewportPoint(part.Position)
                local dist = (Vector2.new(ePos.X, ePos.Y) - center).Magnitude
                if dist < last and onScreen and dist < fov then
                    last = dist
                    nearest = Player
                end
            end
        end
    end
    return nearest
end

RunService.RenderStepped:Connect(function()
    FOVring.Position = Cam.ViewportSize / 2
    FOVring.Visible = aimbotEnabled
    if not aimbotEnabled then return end
    local closest = getClosestPlayerInFOV("Head")
    if closest and closest.Character and closest.Character:FindFirstChild("Head") then
        lookAt(closest.Character.Head.Position)
    end
end)

-- ==================== 无后坐力 ====================
RunService.Stepped:Connect(function()
    if not masterEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local handle = tool:FindFirstChild("Handle")
            if handle then
                handle.Velocity = Vector3.new(0, 0, 0)
                handle.RotVelocity = Vector3.new(0, 0, 0)
            end
            local fireEvent = tool:FindFirstChild("FireEvent")
            if fireEvent then fireEvent:Destroy() end
        end
    end
end)

